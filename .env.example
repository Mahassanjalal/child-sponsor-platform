# ============================================
# HopeConnect - Child Sponsorship Platform
# Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ===================
# REQUIRED VARIABLES
# ===================

# PostgreSQL Database URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/child_sponsorship

# Session Secret (generate a random 32+ character string)
# You can generate one with: openssl rand -base64 32
SESSION_SECRET=your-super-secret-session-key-change-this

# ===================
# STRIPE CONFIGURATION
# ===================
# Get these from https://dashboard.stripe.com/apikeys

# For development, use test keys (sk_test_... and pk_test_...)
# For production, use live keys (sk_live_... and pk_live_...)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook secret for verifying webhooks
# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ===================
# EMAIL CONFIGURATION (Resend)
# ===================
# Get your API key from https://resend.com/api-keys

RESEND_API_KEY=re_...

# Email address to send from (must be verified in Resend)
FROM_EMAIL=noreply@yourdomain.com

# Email to receive contact form submissions
ADMIN_EMAIL=admin@yourdomain.com

# ===================
# APPLICATION SETTINGS
# ===================

# Node environment: development, production, or test
NODE_ENV=development

# Server port (default: 5000)
PORT=5000

# File uploads
# Use "local" to store uploads on disk in ./uploads
# Use "replit" to use Replit Object Storage
UPLOAD_MODE=local

# ===================
# REPLIT CONFIGURATION
# ===================
# These are automatically set when running on Replit
# Only set these if deploying elsewhere

# REPLIT_DOMAINS=your-app.replit.app
# REPLIT_CONNECTORS_HOSTNAME=connectors.replit.com
# REPL_IDENTITY=your-repl-identity

# ===================
# GOOGLE CLOUD STORAGE (Optional)
# ===================
# For file uploads - only needed if using GCS

# GOOGLE_CLOUD_PROJECT_ID=your-project-id
# GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================
# PRODUCTION CHECKLIST
# ============================================
# Before deploying to production, ensure:
# [ ] DATABASE_URL points to production database
# [ ] SESSION_SECRET is a strong random value
# [ ] STRIPE_SECRET_KEY is live key (sk_live_...)
# [ ] RESEND_API_KEY is set
# [ ] FROM_EMAIL is verified in Resend
# [ ] NODE_ENV is set to "production"
# [ ] All webhooks are configured in Stripe dashboard
# ============================================
